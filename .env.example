# VNoctis Manager — Environment Configuration
# Copy this file to .env and adjust values for your setup.

# ── Paths ──────────────────────────────────────────────
# Root directory for all VNoctis Manager data. Sub-directories are derived
# automatically: games, renpy-sdk, data, covers, screenshots, web-builds.
# This is the only path you need to set for a standard installation.
VNM_ROOT=/mnt/user/appdata/vnm

# ── Networking ─────────────────────────────────────────
# Port exposed on the host for the web UI
HOST_PORT=6773

# ── VNDB Integration ──────────────────────────────────
VNDB_API_BASE=https://api.vndb.org/kana
VNDB_RATE_DELAY_MS=200
VNDB_MATCH_THRESHOLD=0.7
METADATA_TTL_DAYS=30

# Optional: VNDB API token for higher rate limits
# Get one at https://vndb.org/u/tokens
VNDB_API_TOKEN=

# ── Steam Integration ─────────────────────────────────
# How often to refresh the cached Steam app list (hours)
STEAM_APPLIST_TTL_HOURS=24

# Rate delay between Steam Store API requests (ms)
STEAM_RATE_DELAY_MS=1500

# ── Builder ────────────────────────────────────────────
BUILD_CONCURRENCY=1

# Ren'Py SDK version — the builder auto-downloads the SDK + web platform
# on first start if they are not already present in RENPY_SDK_PATH.
RENPY_SDK_VERSION=8.5.2

# ── Image Compression (Web Builds) ────────────────────
# When "Compress assets" is checked in the build dialog, images are
# compressed before web_build to reduce download size.
# Uses a temporary overlay — original game files are never modified.

# JPEG quality target (0-100). Lower = smaller files, more artifacts.
COMPRESS_JPEG_QUALITY=80

# PNG quality range for pngquant (min-max, 0-100). Lossy palette quantization.
COMPRESS_PNG_QUALITY=60-80

# WebP quality target (0-100). Only applies to .webp source images.
COMPRESS_WEBP_QUALITY=80

# Parallel compression workers (0 = auto, uses all available cores).
COMPRESS_WORKERS=0

# ── General ────────────────────────────────────────────
# Persistent log file directory (inside the container). Defaults to /data/logs.
# LOG_PATH=/data/logs
LOG_LEVEL=info
TZ=America/Chicago

# ── Authentication ─────────────────────────────────────
# Admin login username — seeds the initial admin account on first startup (default: admin)
VNM_ADMIN_USER=admin

# Admin login password — seeds the initial admin account on first startup (REQUIRED)
# After first startup, passwords are managed via the User Management panel.
VNM_ADMIN_PASSWORD=

# Set to 'true' to force-reset the admin password from VNM_ADMIN_PASSWORD on next startup.
# Useful for password recovery. Remove or set to 'false' after reset.
# RESET_ADMIN_PASSWORD=false

# JWT signing secret (auto-generated and persisted if not set)
# VNM_JWT_SECRET=

# How many days login sessions remain valid (default: 30)
VNM_SESSION_TTL_DAYS=30

# ── Cloudflare R2 Publishing ───────────────────────────
# Set to true to switch to the R2-enabled database (vnm-r2.db).
# On first run, vnm-r2.db is automatically copied from vnm.db so your
# existing library is preserved. R2 credentials are then configured
# in the admin settings panel — they are NOT stored here.
VNM_R2_MODE=false

# ── User/Group IDs ─────────────────────────────────────
# File permission mapping for bind mounts (Unraid default: 99/100)
PUID=99
PGID=100
