datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Game {
  id                String         @id                    // Stable fingerprint UUID
  directoryPath     String         @unique                // Absolute path in container
  directoryName     String                                // Raw directory name
  extractedTitle    String                                // Title from options.rpy or dir name
  vndbId            String?                               // e.g. "v17"
  steamAppId        String?                               // Steam application ID
  vndbTitle         String?                               // English title from VNDB
  vndbTitleOriginal String?                               // Japanese/original title
  synopsis          String?                               // Full synopsis
  developer         String?                               // Developer studio
  releaseDate       DateTime?                             // First release date
  lengthMinutes     Int?                                  // Estimated play time
  vndbRating        Float?                                // Score 0-10
  coverPath         String?                               // Local path to cached cover
  tags              String         @default("[]")         // JSON array of { id, name, spoiler }
  screenshots       String         @default("[]")         // JSON array of screenshot URLs
  buildStatus       String         @default("not_built")  // not_built|queued|building|built|failed|stale
  hidden            Boolean        @default(false)        // User-hidden from library view
  publishStatus     String         @default("not_published") // not_published|publishing|published|failed (R2 mode only)
  publishedAt       DateTime?                             // Last successful publish time
  publishedVersion  String?                               // Hash of published build
  favorite          Boolean        @default(false)        // DEPRECATED — kept for data migration; will be dropped in a follow-up migration
  buildJobId        String?                               // Most recent build job ID
  builtAt           DateTime?                             // Last successful build time
  webBuildPath      String?                               // URL to compiled web export
  metadataSource    String         @default("unmatched")  // auto|manual|unmatched
  metadataFetchedAt DateTime?                             // Last VNDB fetch time
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  favoritedBy       UserFavorite[]                        // Per-user favorites (replaces global favorite)
}

model User {
  id           String         @id @default(uuid())
  username     String         @unique
  passwordHash String                                     // bcrypt hash (cost factor 12)
  role         String         @default("viewer")          // "admin" | "viewer"
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  favorites    UserFavorite[]
}

model UserFavorite {
  userId    String
  gameId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@id([userId, gameId])
}

model BuildJob {
  id          String    @id @default(uuid())
  gameId      String
  status      String    @default("queued")    // queued|building|done|failed|cancelled
  logPath     String?                         // Path to build log file
  startedAt   DateTime?
  completedAt DateTime?
  error       String?                         // Error message if failed
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model ScanJob {
  id              String    @id @default(uuid())
  status          String    @default("running")  // running|completed|failed
  gamesFound      Int       @default(0)
  gamesNew        Int       @default(0)
  gamesRemoved    Int       @default(0)
  error           String?
  startedAt       DateTime  @default(now())
  completedAt     DateTime?
}

// ── R2 Publish models (only present in vnm-r2.db) ────────
// Applied via raw SQL in R2 mode; never via a Prisma migration so that
// vnm.db (the non-R2 database) remains clean.

model Setting {
  key       String   @id
  value     String                  // AES-256-GCM encrypted for secrets
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PublishJob {
  id            String    @id @default(uuid())
  gameId        String
  status        String    @default("queued")    // queued|uploading|done|failed|cancelled
  progress      Int       @default(0)           // 0-100 percentage
  filesTotal    Int       @default(0)
  filesUploaded Int       @default(0)
  error         String?
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}
