{
  "name": "vnm-api",
  "version": "0.1.0",
  "private": true,
  "description": "VNoctis Manager — REST API service (Fastify + Prisma)",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
