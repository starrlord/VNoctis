    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^8.1.0",
    "@prisma/client": "^6.5.0",
    "fastify": "^5.3.3",
    "jsonwebtoken": "^9.0.3",
    "pino": "^9.6.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.9",
    "prisma": "^6.5.0"
  }
}
